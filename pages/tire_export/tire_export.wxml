<view class="container safe-bottom">
  <view class="page-title">数据导出</view>

  <view class="card">
    <text class="card-title">选择导出内容</text>

    <!-- 类型筛选 -->
    <view class="filter-label">导出类型</view>
    <view class="type-filter">
      <view class="type-tag {{exportType === '' ? 'active' : ''}}" bindtap="setType" data-type="">全部</view>
      <view class="type-tag {{exportType === 'purchase' ? 'active' : ''}}" bindtap="setType" data-type="purchase">进货</view>
      <view class="type-tag {{exportType === 'sale' ? 'active' : ''}}" bindtap="setType" data-type="sale">出库</view>
    </view>

    <!-- 日期范围 -->
    <view class="filter-label">日期范围（可选）</view>
    <view class="date-row">
      <picker mode="date" value="{{dateFrom}}" bindchange="onDateFromChange">
        <view class="date-picker-val">{{dateFrom || '开始日期'}}</view>
      </picker>
      <text class="date-sep">至</text>
      <picker mode="date" value="{{dateTo}}" bindchange="onDateToChange">
        <view class="date-picker-val">{{dateTo || '结束日期'}}</view>
      </picker>
    </view>

    <!-- 导出按钮 -->
    <button class="export-btn" bindtap="doExport" disabled="{{exporting}}">
      {{exporting ? '生成中...' : '导 出 CSV'}}
    </button>
  </view>

  <!-- 导出结果 -->
  <view wx:if="{{exportResult}}" class="card">
    <text class="card-title">✅ 导出成功</text>
    <view class="result-info">
      <text class="ri-line">文件名: {{exportResult.filename}}</text>
      <text class="ri-line">记录数: {{exportResult.totalRows}} 条</text>
    </view>
    <view class="result-actions">
      <button class="action-btn" bindtap="preview">预览文件</button>
      <button class="action-btn outline" bindtap="copyLink">复制文件ID</button>
    </view>
    <view class="result-hint">文件已上传至云存储 exports/ 目录</view>
  </view>
</view>
