<view class="header">
  <van-image class="pic" round fit='cover' width="120rpx" height="120rpx" src="{{avatarUrl}}" />
  <view class="name" bindtap="onLogin">{{nickName || '点击登录'}}</view>
</view>
<view class="total">
  <view class="item">
    <view class="text1">订房订单数</view>
    <view class="text2">{{roomOrderNum}}</view>
  </view>
  <view class="item">
    <view class="text1">订餐订单数</view>
    <view class="text2">{{foodOrderNum}}</view>
  </view>
</view>
<view class="bigTit">我的订单</view>
<view class="warp">
  <van-cell is-link icon="hotel-o" title="订房订单" link-type="navigateTo" bindtap="goList" id="0" />
  <van-cell is-link icon="points" title="订餐订单" link-type="navigateTo" bindtap="goFood" />
</view>
<view class="bigTit" style="margin-top:30rpx">我的评价</view>
<view class="warp">
  <van-cell is-link icon="comment-o" title="我的评价" link-type="navigateTo" bindtap="goEval" />
</view>
<van-dialog use-slot title="完善资料" show="{{ showUser }}" show-cancel-button bind:close="onCloseUser" bind:confirm="onCloseUser">
  <view style="padding:20rpx;display:flex;flex-direction:column;align-items:center;gap:20rpx">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <van-image round fit="cover" width="100rpx" height="100rpx" src="{{avatarUrl || 'cloud://cloud1-d2gek3mad0a97e6a8.636c-cloud1-d2gek3mad0a97e6a8-1436450565/hotel/default-avatar.png'}}" />
    </button>
    <input type="nickname" class="nickname-input" placeholder="请输入昵称" value="{{nickName}}" bindinput="onInputNickname" />
  </view>
</van-dialog>

<tabbar tabActive="{{tabActive}}" />