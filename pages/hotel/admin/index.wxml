<!-- 酒店图片管理页 — 手机端批量管理房型/菜品/文章的照片 -->
<view class="container">
  <!-- 分类切换 Tab -->
  <view class="tabs">
    <view class="tab {{activeTab === 'roomTypes' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="roomTypes">房型</view>
    <view class="tab {{activeTab === 'foods' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="foods">菜品</view>
    <view class="tab {{activeTab === 'articles' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="articles">文章</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <van-loading type="spinner" color="#d5b075" />
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空数据 -->
  <van-empty wx:if="{{!loading && list.length === 0}}" description="暂无数据" />

  <!-- 记录列表 -->
  <scroll-view wx:if="{{!loading}}" class="list" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="item" wx:for="{{list}}" wx:key="_id">
      <view class="item-name">{{item.displayName}}</view>
      <view class="item-photo" bindtap="onChangePhoto" data-id="{{item._id}}" data-name="{{item.displayName}}">
        <van-image wx:if="{{item.displayPhoto}}" src="{{item.displayPhoto}}" width="160rpx" height="160rpx" fit="cover" radius="8rpx" />
        <image wx:else src="cloud://cloud1-d2gek3mad0a97e6a8.636c-cloud1-d2gek3mad0a97e6a8-1436450565/hotel/default-room.jpg" mode="aspectFill" class="item-placeholder" />
        <view class="item-overlay">
          <text class="overlay-text">点击换图</text>
        </view>
      </view>
      <view class="item-status">
        <text wx:if="{{item.displayPhoto}}" class="status-ok">✓ 已设置</text>
        <text wx:else class="status-empty">✗ 未设置</text>
      </view>
    </view>

    <!-- 底部提示 -->
    <view class="footer-tip" wx:if="{{list.length > 0}}">
      <text>共 {{list.length}} 条记录</text>
      <text class="tip-small"> | 点击图片即可更换</text>
    </view>
  </scroll-view>

  <!-- 上传中遮罩 -->
  <view wx:if="{{uploading}}" class="upload-mask">
    <view class="upload-toast">
      <van-loading type="spinner" color="#fff" />
      <text class="upload-text">正在上传...</text>
    </view>
  </view>
</view>
